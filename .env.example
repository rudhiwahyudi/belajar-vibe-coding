# Formspree form ID used by the contact page (https://formspree.io)
# Create a form at formspree.io and copy the ID from the endpoint URL:
# https://formspree.io/f/<FORM_ID>
VITE_FORMSPREE_ID=your-form-id

# Supabase — create a project at supabase.com, then copy from:
# Project Settings → API → Project URL & anon/public key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
